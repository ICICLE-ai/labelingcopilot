# Model API provider
# Set to "azure" or "openai". If omitted, the app auto-detects based on available credentials.
MODEL_API_PROVIDER=

# ---------------------------------------------------------------------------
# Azure OpenAI Configuration
# ---------------------------------------------------------------------------
# Vision API (for analyzing images and generating augmentation suggestions)
AZURE_VISION_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_VISION_API_KEY=your-vision-api-key-here
AZURE_VISION_DEPLOYMENT=gpt-5.4-nano
AZURE_VISION_API_VERSION=2024-12-01-preview

# Image Editing API (for applying transformations)
AZURE_IMAGE_EDIT_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_IMAGE_EDIT_API_KEY=your-image-edit-api-key-here
AZURE_IMAGE_EDIT_DEPLOYMENT=gpt-image-1.5
AZURE_IMAGE_EDIT_API_VERSION=2025-04-01-preview

# ---------------------------------------------------------------------------
# Standard OpenAI Configuration
# ---------------------------------------------------------------------------
# Minimal setup:
#   MODEL_API_PROVIDER=openai
#   OPENAI_API_KEY=your-openai-api-key-here
#
# Optional overrides:
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_VISION_MODEL=gpt-5.4-nano
OPENAI_IMAGE_EDIT_MODEL=gpt-image-1.5
OPENAI_VISION_API_KEY=
OPENAI_IMAGE_EDIT_API_KEY=

# Retrieval integration
# Relative image URLs such as /images/example.jpg are resolved against this base.
# Docker Compose overrides this to host.docker.internal automatically.
SYNTHESIS_RETRIEVAL_BASE_URL=http://localhost:8000

# Processing Configuration
BATCH_SIZE=10

# Rate limiting
# Adjust these to match your provider quota.
MAX_CONCURRENT=1
REQUESTS_PER_MINUTE=20

# Other processing settings
MAX_RETRIES=3
MIN_FILE_SIZE=1024
TEMPERATURE=0.7
MAX_TOKENS=4096

# Forte OOD Detection (Optional)
FORTE_ENABLED=false
FORTE_METHOD=gmm
FORTE_K_NEIGHBORS=5
FORTE_THRESHOLD=0.3
FORTE_EMBEDDING_DIR=./embeddings

# Evaluation Metrics (Enable/disable specific metrics)
EVAL_PRDC=true
EVAL_FD=true
EVAL_FLS=false
EVAL_INCEPTION=true
EVAL_AUTHPCT=true
EVAL_CT=false
EVAL_MMD=false
EVAL_VENDI=true
EVAL_SW=true
EVAL_PRDC_K=5
